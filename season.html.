<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Season - AL BARQY Collector</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700;900&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #0A0A0A; color: #fff; }
        .font-luxury { font-family: 'Cinzel', serif; }
        .text-gold { color: #D4AF37; }
        .bg-gold { background-color: #D4AF37; }
        .card-season { transition: all 0.3s ease; }
        .card-season:hover { transform: translateY(-5px); border-color: #D4AF37; box-shadow: 0 10px 30px rgba(212,175,55,0.2); }
    </style>
</head>
<body class="min-h-screen bg-[#0A0A0A] text-white">

    <!-- Navigasi Atas (Sama seperti halaman lain) -->
    <nav class="fixed w-full z-50 bg-black/80 backdrop-blur-md border-b border-gold/20 px-6 py-4 flex justify-between items-center">
        <div class="flex items-center gap-3">
            <a href="index.html" class="font-luxury text-xl font-bold text-gold">AL BARQY</a>
            <span class="text-xs text-gold/50 uppercase tracking-widest border-l border-gold/30 pl-3">Season</span>
        </div>
        <div class="flex gap-6 text-sm font-light tracking-wide">
            <a href="profile.html" class="hover:text-gold transition">Profile</a>
            <a href="index.html" class="hover:text-gold transition">Home</a>
        </div>
    </nav>

    <!-- Konten Utama -->
    <div class="pt-32 pb-20 px-6 max-w-6xl mx-auto">

        <!-- Judul Halaman -->
        <div class="text-center mb-16">
            <h1 class="font-luxury text-5xl text-gold tracking-widest">Season 1</h1>
            <p class="text-gray-400 tracking-[0.2em] uppercase text-sm mt-2">Sweet Vanilla Collection</p>
            <div class="mt-4 inline-block px-4 py-1 border border-gold/30 rounded-full text-xs text-gold">Active Season</div>
        </div>

        <!-- Grid Koleksi (Produk) -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

            <!-- Kartu 1: Sweet Vanilla (Sudah Dimiliki) -->
            <div class="card-season bg-[#121212] rounded-2xl border border-gold/40 p-6 relative overflow-hidden group">
                <div class="absolute top-4 right-4 bg-gold text-black text-[10px] font-bold px-3 py-1 rounded-full">OWNED</div>
                <div class="flex flex-col items-center">
                    <div class="w-32 h-32 bg-gold/10 rounded-full flex items-center justify-center mb-4 border-2 border-gold/30">
                        <span class="text-6xl">🌿</span>
                    </div>
                    <h2 class="font-luxury text-2xl text-gold">Sweet Vanilla</h2>
                    <p class="text-gray-400 text-sm mt-1">Season 1</p>
                    <p class="text-xs text-gold/70 mt-3">Tier: Pearl 30ml • Poin: +3</p>
                    <button class="mt-6 w-full py-2 bg-gold/20 border border-gold/50 text-gold rounded-lg text-sm hover:bg-gold hover:text-black transition">
                        Lihat Detail
                    </button>
                </div>
            </div>

            <!-- Kartu 2: Starlight Edition (Edisi Terbatas / Belum Punya) -->
            <div class="card-season bg-[#121212] rounded-2xl border border-gray-700/50 p-6 relative overflow-hidden opacity-80 hover:opacity-100">
                <div class="absolute top-4 right-4 bg-purple-600 text-white text-[10px] font-bold px-3 py-1 rounded-full">LIMITED</div>
                <div class="flex flex-col items-center">
                    <div class="w-32 h-32 bg-purple-900/20 rounded-full flex items-center justify-center mb-4 border-2 border-purple-500/30">
                        <span class="text-6xl">⭐</span>
                    </div>
                    <h2 class="font-luxury text-2xl text-gray-400">Starlight Edition</h2>
                    <p class="text-gray-500 text-sm mt-1">Season 1 Exclusive</p>
                    <div class="mt-3 px-3 py-1 bg-red-900/50 border border-red-500/50 text-red-400 text-[10px] rounded-full uppercase tracking-widest">Sold Out</div>
                    <button class="mt-6 w-full py-2 bg-gray-800 text-gray-500 rounded-lg text-sm cursor-not-allowed">
                        Tidak Tersedia
                    </button>
                </div>
            </div>

        </div>
    </div>

</body>
</html>
